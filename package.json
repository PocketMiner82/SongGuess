{
  "name": "songguess",
  "version": "3.1.1-dev.5",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env localdev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "clean": "rm -rf public/dist",
    "build": "node build-html.js && postcss ./src/client/global.css -o ./public/dist/global.css && esbuild src/client/*.tsx --bundle --splitting --format=esm --platform=browser --outdir=public/dist --define:process.env.NODE_ENV=\\\"production\\\" --minify",
    "build:localdev": "node build-html.js && postcss ./src/client/global.css -o ./public/dist/global.css && esbuild src/client/*.tsx --bundle --splitting --format=esm --platform=browser --outdir=public/dist",
    "typegen": "wrangler types ./src/server/worker-configuration.d.ts",
    "check": "tsc && eslint src/ && wrangler deploy --dry-run"
  },
  "dependencies": {
    "@syncfm/applemusic-api": "^0.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "chroma-js": "^3.2.0",
    "cookie": "^1.1.1",
    "esbuild": "^0.28.1",
    "fuzzball": "^2.2.6",
    "howler": "^2.2.4",
    "itunes-store-api": "^2.1.0",
    "lodash": "^4.18.1",
    "papaparse": "^5.5.3",
    "partyserver": "^0.5.6",
    "partysocket": "^1.2.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "react": "^19.2.7",
    "react-cookie": "^8.1.2",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-modal-global": "^2.3.7",
    "react-toastify": "^11.1.0",
    "soundcloud.ts": "^0.7.4",
    "tailwindcss": "^4.3.0",
    "unique-username-generator": "^1.5.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint-react/eslint-plugin": "^5.8.19",
    "@types/chroma-js": "^3.1.2",
    "@types/howler": "^2.2.13",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
